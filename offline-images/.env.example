# ==============================================================================
# DataAgent Studio — 环境变量配置模板
# 复制此文件为 .env，仅需修改以下几项即可启动。
#
# 模型地址、Embedding 模型、RAG 参数、功能开关等均在 /admin 界面配置，
# 无需在此处填写。
# ==============================================================================

# ── 安全密钥（必改）─────────────────────────────────────────────────────────────
# 用于 JWT 签名，生产环境必须替换为随机值。
# 生成命令: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-64-char-string

# ── 初始管理员账号 ─────────────────────────────────────────────────────────────
# 仅首次启动时生效，之后通过 /admin 界面管理用户。
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=990115

# ── 端口（按需修改，默认 80/8000）────────────────────────────────────────────────
FRONTEND_PORT=80
BACKEND_PORT=8000
