# ==============================================================================
# DataAgent Studio — 环境变量配置模板
# 复制此文件为 .env，仅需修改以下几项即可启动。
#
# 模型地址、Embedding 模型、RAG 参数、功能开关等均在 /admin 界面配置，
# 无需在此处填写。
# ==============================================================================

# ── 安全密钥（必改）─────────────────────────────────────────────────────────────
# 用于 JWT 签名，生产环境必须替换为随机值。
# 生成命令: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-64-char-string

# ── 初始管理员账号 ─────────────────────────────────────────────────────────────
# 仅首次启动时生效，之后通过 /admin 界面管理用户。
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=990115

# ── 端口（按需修改，默认 80/8000）────────────────────────────────────────────────
FRONTEND_PORT=80
BACKEND_PORT=8000

# ── 数据库（sqlite 或 postgresql）────────────────────────────────────────────────
# SQLite（默认，开发环境）
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
DATABASE_TYPE=sqlite

# PostgreSQL（生产环境，知识库扩展后推荐）
# DATABASE_URL=postgresql+asyncpg://dataagent:dataagent@postgres:5432/dataagent
# DATABASE_TYPE=postgresql

# ── 外部算力服务器（Embedding + LLM，OpenAI-compatible）──────────────────────────
# 默认使用本项目的 BGE-M3 embedding 集群（4 节点 + nginx 负载均衡）
# 集群启动：cd embedding && docker compose up -d
# EMBED_BASE_URL=http://embedding-lb:8080/v1
# EMBED_API_KEY=your-api-key
EMBED_MODEL=bge-m3
EMBED_BATCH_SIZE=64

# ── Embedding 集群配置（仅在启动 embedding/docker-compose.yml 时生效）───────────
EMBED_REPLICAS=4
EMBED_LB_PORT=8080
EMBED_DEVICE=auto
EMBED_CPU_LIMIT=4.0
EMBED_MEMORY_LIMIT=4G
TRANSFORMERS_OFFLINE=0

# ── 向量存储（sqlite 或 qdrant）─────────────────────────────────────────────────
VECTOR_STORE_TYPE=sqlite
# QDRANT_URL=http://qdrant:6333
# QDRANT_COLLECTION=kb_chunks
# QDRANT_API_KEY=
