# ==============================================================================
# 深研AI 多智能体平台 - 环境变量配置
# 复制此文件为 .env 并按实际环境修改
# ==============================================================================

# ------------------------------------------------------------------------------
# Security (安全配置)
# ------------------------------------------------------------------------------
# 生产环境必须修改为随机 64 字节字符串
# 生成命令: cat /dev/urandom | tr -dc 'a-zA-Z0-9' | fold -w 64 | head -n 1
SECRET_KEY=change-this-to-a-random-64-char-string

# ------------------------------------------------------------------------------
# LLM Configuration (大模型配置 - 兼容 OpenAI API)
# ------------------------------------------------------------------------------
# Ollama (本地部署):
#   DEFAULT_LLM_BASE_URL=http://ollama-host:11434/v1
#   DEFAULT_LLM_API_KEY=ollama
#
# vLLM:
#   DEFAULT_LLM_BASE_URL=http://vllm-host:8080/v1
#   DEFAULT_LLM_API_KEY=token-abc123
#
# OpenAI 兼容网关 (内网代理):
#   DEFAULT_LLM_BASE_URL=http://llm-gateway.internal/v1
#   DEFAULT_LLM_API_KEY=your-internal-api-key
#
DEFAULT_LLM_BASE_URL=http://localhost:11434/v1
DEFAULT_LLM_MODEL=qwen2.5:72b
DEFAULT_LLM_API_KEY=ollama

# ------------------------------------------------------------------------------
# Feature Flags (功能开关)
# ------------------------------------------------------------------------------
# 内网部署: ENABLE_EXTERNAL_SEARCH 必须为 false
ENABLE_EXTERNAL_SEARCH=false
ENABLE_BROWSER=true
SANDBOX_TIMEOUT=30
MAX_WORKERS=10

# ------------------------------------------------------------------------------
# Database (数据库配置)
# ------------------------------------------------------------------------------
# 默认使用 SQLite (开发/小规模部署)
DATABASE_URL=sqlite:///./data/app.db

# PostgreSQL (生产/大规模部署，取消注释并填写连接信息)
# DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/deepresearch

# ------------------------------------------------------------------------------
# Ports (端口配置)
# ------------------------------------------------------------------------------
FRONTEND_PORT=80
BACKEND_PORT=8000
