  "analysis_frameworks": {
    "swot": {
      "description": "Strengths-Weaknesses-Opportunities-Threats strategic analysis",
      "quadrants": ["优势(S)", "劣势(W)", "机会(O)", "威胁(T)"],
      "usage": "评估企业竞争地位；将内部因素(S/W)与外部因素(O/T)分离分析"
    },
    "pest": {
      "description": "Political-Economic-Social-Technological macro-environment analysis",
      "dimensions": {
        "political": "政策法规、监管环境、政府支持/限制",
        "economic": "GDP增速、利率、汇率、消费者信心、通胀",
        "social": "人口结构、城镇化率、消费偏好、文化变迁",
        "technological": "技术成熟度、数字化程度、R&D投入、专利布局"
      }
    },
    "porter_five_forces": {
      "description": "Michael Porter's competitive intensity framework",
      "forces": {
        "rivalry": "现有竞争者之间的博弈强度",
        "new_entrants": "新进入者威胁（壁垒高低）",
        "substitutes": "替代品威胁",
        "buyer_power": "买方议价能力",
        "supplier_power": "供应商议价能力"
      },
      "scoring": "每个力量打1-5分，综合判断行业吸引力"
    },
    "bcg_matrix": {
      "description": "波士顿矩阵 — 市场份额 vs 市场增速",
      "quadrants": {
        "stars": "高增速+高份额 — 增加投入，保持领先",
        "cash_cows": "低增速+高份额 — 收割利润，维持运营",
        "question_marks": "高增速+低份额 — 选择性投入或退出",
        "dogs": "低增速+低份额 — 考虑剥离"
      }
    },
    "mece": {
      "description": "Mutually Exclusive Collectively Exhaustive — 相互独立，完全穷尽",
      "usage": "结构化分析问题，确保分类不重叠不遗漏",
      "examples": ["按地区: 华北/华东/华南/华西", "按客户规模: 大企业/中企/小微", "按产品周期: 导入期/成长期/成熟期/衰退期"]
    },
    "scqa": {
      "description": "Situation-Complication-Question-Answer — McKinsey金字塔叙事",
      "structure": {
        "S": "现状 — 受众已知、不会引发争议的事实",
        "C": "冲突/张力 — 打破现状的变化、问题或危机",
        "Q": "由SC自然引发的核心问题",
        "A": "回答该问题的核心建议/结论"
      },
      "ppt_application": "标题→S，第2页→C，第3页→Q，主体→A"
    },
    "7s_framework": {
      "description": "麦肯锡7S — 组织变革诊断",
      "hard_elements": ["战略(Strategy)", "结构(Structure)", "系统(Systems)"],
      "soft_elements": ["共同价值观(Shared Values)", "技能(Skills)", "风格(Style)", "员工(Staff)"]
    }
  },

