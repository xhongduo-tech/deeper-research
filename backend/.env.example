# Copy this file to .env and fill in your values

# Database (default: SQLite, switch to PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./app.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/multiagent

# Redis
REDIS_URL=redis://redis:6379

# Security
SECRET_KEY=change-me-to-a-long-random-string-in-production

# LLM Configuration (OpenAI-compatible)
DEFAULT_LLM_BASE_URL=https://api.openai.com/v1
DEFAULT_LLM_MODEL=gpt-4o
DEFAULT_LLM_API_KEY=sk-your-api-key-here

# Feature flags
ENABLE_EXTERNAL_SEARCH=false
ENABLE_BROWSER=true
SANDBOX_TIMEOUT=30
MAX_WORKERS=10

# File storage
UPLOAD_DIR=./uploads
TEMPLATE_DIR=./templates
SANDBOX_WORKSPACE=./sandbox_workspace

# Default admin credentials (change after first login!)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123456

# Debug mode
DEBUG=false
